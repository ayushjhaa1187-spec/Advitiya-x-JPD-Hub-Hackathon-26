PORT=5000
# Update these with your local Postgres details
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=smartlinkhub
DB_PORT=5432
JWT_SECRET=super_secret_key_change_this
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# URLs
BACKEND_URL=https://advitiya.jpdlab.co.in
FRONTEND_URL=https://ayushjhaa1187-spec.github.io/Advitiya-x-JPD-Hub-Hackathon-26/frontend


# Production Environment Settings
NODE_ENV=production

# CORS Settings (required for frontend to connect)
CORS_ORIGIN=https://ayushjhaa1187-spec.github.io

# Database Connection (for production deployment)
# Option 1: Use individual DB variables (shown above)
# Option 2: Use full DATABASE_URL (for services like Render, Heroku)
DATABASE_URL=postgresql://username:password@host:5432/smartlinkhub

# Session Configuration
SESSION_SECRET=your_session_secret_change_this

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Level
LOG_LEVEL=info
